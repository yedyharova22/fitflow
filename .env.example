# Database
DATABASE_URL=postgresql://fitflow:fitflow@localhost:5432/fitflow

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# API
API_PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# JWT (min 32 characters)
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Logging
LOG_LEVEL=info

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000

# Cloudinary (avatar uploads — optional in development; local storage fallback is used instead)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public API URL used for locally stored avatar links (defaults to http://localhost:4000)
# API_PUBLIC_URL=http://localhost:4000

# Web Push (optional — foundation for M5; leave empty in dev)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@fitflow.dev
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
