    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "rrule": "^2.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "dotenv-cli": "^8.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
