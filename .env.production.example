# Production environment template — copy to .env and fill in secrets before deploy.
# Usage: docker compose -f docker-compose.prod.yml --env-file .env up -d --build

# Postgres (used by docker-compose.prod.yml)
POSTGRES_USER=fitflow
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=fitflow

# Host ports
API_PORT=4000
WEB_PORT=3000

# Database & Redis (internal URLs are set in compose; override only if using external services)
DATABASE_URL=postgresql://fitflow:change-me-strong-password@postgres:5432/fitflow
REDIS_URL=redis://redis:6379

# API
NODE_ENV=production
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=https://your-domain.com
LOG_LEVEL=info
API_PUBLIC_URL=https://api.your-domain.com

# Frontend (baked into web image at build time)
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# Cloudinary (optional — avatar uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Web Push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
